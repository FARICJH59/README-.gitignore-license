{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "agents": ["runtime/shims/agents"],
      "agents/*": ["runtime/shims/*", "backend/agents/*", "frontend/src/agents/*"]
    }
  },
  "include": ["backend/**/*", "frontend/src/**/*", "runtime/**/*", "scripts/**/*.ts", "cli/**/*"]
}
